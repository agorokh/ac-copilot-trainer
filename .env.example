# Copy to .env and fill in locally. Never commit .env.
#
# Preferred (fleet / multi-machine): **Doppler** — see repo-root `doppler.yaml` (project
# `ag-dev-ecosystem`) and `AGENTS.md` § Local development. Use `doppler run -- …` so LLM + GitHub keys
# match across machines without copying `.env` files.

# Example: LLM provider (customize per project)
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# DISTILL_API_KEY=          # optional; when set, wins over OPENAI_/OPENROUTER_ for distill.py
# DISTILL_BASE_URL=         # optional; include scheme, e.g. https://api.openai.com/v1 (default)
# DISTILL_MODEL=            # optional model id for distillation
# DISTILL_MAX_TOKENS=       # optional completion cap for distill.py (default 4096)
# OLLAMA_HOST=http://127.0.0.1:11434

# Example: database (customize per project)
# DATABASE_URL=

# Claude Code — GitHub MCP (Docker: ghcr.io/github/github-mcp-server; see TOOLCHAIN.md, GITHUB_SETUP.md)
# Fine-grained or classic PAT; never commit. Export before `claude` so the MCP container receives it.
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Child-repo GitHub Actions only: PAT with issues:write on the upstream template repo (see MAINTAINING_THE_TEMPLATE.md, template-feedback workflow). Do not use in local dev unless testing gh CLI.
# TEMPLATE_REPO_TOKEN=

# Process miner (optional): JSON object merging extra GitHub login → short bot_name keys into defaults (see tools/process_miner/bot_authorship.py).
# PROCESS_MINER_BOT_ALIASES_JSON={"my-bot-login":"mybot"}
