# Copy to .env and fill in locally. Never commit .env.

# Example: LLM provider (customize per project)
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_HOST=http://127.0.0.1:11434

# AC Copilot Trainer — sidecar post-lap debrief (issue #46). Localhost-only; opt-in.
# Tested with Ollama 0.5.x (`ollama --version`). Default model below matches `llm_coach` default.
# AC_COPILOT_OLLAMA_ENABLE=1
# AC_COPILOT_OLLAMA_HOST=http://127.0.0.1:11434
# AC_COPILOT_OLLAMA_MODEL=llama3.2
# AC_COPILOT_OLLAMA_TEMPERATURE=0.35
# AC_COPILOT_OLLAMA_NUM_PREDICT=320
# AC_COPILOT_OLLAMA_TIMEOUT_SEC=45
# AC_COPILOT_OLLAMA_DEBRIEF_TIMEOUT_SEC=12

# Example: database (customize per project)
# DATABASE_URL=

# Claude Code — GitHub MCP (Docker: ghcr.io/github/github-mcp-server; see TOOLCHAIN.md, GITHUB_SETUP.md)
# Fine-grained or classic PAT; never commit. Export before `claude` so the MCP container receives it.
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Child-repo GitHub Actions only: PAT with issues:write on the upstream template repo (see MAINTAINING_THE_TEMPLATE.md, template-feedback workflow). Do not use in local dev unless testing gh CLI.
# TEMPLATE_REPO_TOKEN=
