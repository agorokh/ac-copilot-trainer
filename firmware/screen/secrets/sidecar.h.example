// Copy to firmware/screen/secrets/sidecar.h and fill in.
// This file is gitignored; the real sidecar.h MUST NEVER be committed.
#pragma once

// LAN IP of the PC that runs Assetto Corsa + the ai_sidecar. Use a reserved
// DHCP lease (or static IP) on the router so this does not drift.
#define SIDECAR_HOST  "192.168.1.100"
#define SIDECAR_PORT  8765
#define SIDECAR_PATH  "/"

// Shared secret the sidecar will check on the WS upgrade header
// X-AC-Copilot-Token. Match what you start the sidecar with:
//   py -3 -m tools.ai_sidecar --host 0.0.0.0 --port 8765 --token <this>
// Generate once: `python -c "import secrets; print(secrets.token_urlsafe(24))"`
#define SIDECAR_TOKEN "replace-with-token-from-sidecar-startup"

// Identifier the sidecar uses to log which external client connected.
#define CLIENT_ID     "ac-copilot-screen-01"
